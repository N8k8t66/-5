@model WebApplication1665.Models.GuestResponse

@{
    Layout = null;
}

<!DOCTYPE html>

<html>
<head>
    <meta name="viewport" content="width=device-width" />
    <title>RsvpForm</title>
</head>
<body>
    @using (Html.BeginForm())
    {
        <p>@Html.LabelFor(x => x.Operand1)
        @Html.TextBoxFor(x => x.Operand1, new { @class = "calculator-input", type = "number", step = "1" })</p>
        <p>@Html.LabelFor(x => x.Operand2)
        @Html.TextBoxFor(x => x.Operand2, new { @class = "calculator-input", type = "number", step = "1" })</p>
        <p>
        @Html.LabelFor(x => x.Operand2)
             @Html.ListBox(x => x.Operation, new[] {
        new SelectListItem() { "+", "-", "*", "/" }, new { @class = "calculator-input" }})
        </p>
        <input type="submit" value="Вычислить" />
    }
</body>
</html>
